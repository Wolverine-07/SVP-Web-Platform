# ─────────────────────────────────────────────────────────────
#  SVP Analytics Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  Run:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# Local PostgreSQL (created by `npm run setup`):
DATABASE_URL="postgresql://svp_user:svp123@localhost:5432/svp_analytics"
# Neon / cloud:
# DATABASE_URL="postgresql://user:pass@<host>:5432/<db>?sslmode=require"

# ── Server ──────────────────────────────────────────────────
PORT=4001
NODE_ENV=development          # development | production

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=24h

# ── CORS ────────────────────────────────────────────────────
# Local dev:
# CORS_ORIGIN=http://localhost:5173
# Production (comma-separated):
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=*

# ── SMTP (optional — only needed for password-reset emails) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SVP Analytics <your-email@gmail.com>"
